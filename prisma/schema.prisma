generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Roles del sistema (Admin, Employee, Client, Wholesaler).
model Role {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @unique @db.VarChar(50)
  description String?
  created_at  DateTime? @default(now()) @db.Timestamp(6)
  users       User[]

  @@map("roles")
}

model User {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  role_id       String     @db.Uuid
  email         String     @unique @db.VarChar(255)
  password_hash String     @db.VarChar(255)
  first_name    String     @db.VarChar(100)
  last_name     String     @db.VarChar(100)
  phone         String?    @db.VarChar(50)
  created_at    DateTime?  @default(now()) @db.Timestamp(6)
  updated_at    DateTime?  @default(now()) @updatedAt @db.Timestamp(6)
  audit_logs    AuditLog[]
  orders        Order[]
  role          Role       @relation(fields: [role_id], references: [id], onUpdate: NoAction)

  @@map("users")
}

/// Producto maestro. Stock gestionado en silos separados.
model Product {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  category        String          @db.VarChar(100)
  brand           String          @db.VarChar(100)
  model           String          @db.VarChar(100)
  description     String?         @db.Text
  /// En PostgreSQL, TEXT soporta índices GIN/GiST completos sin prefix.
  compatibility   String?
  price           Decimal         @db.Decimal(10, 2)
  image_url       String?         @db.VarChar(500)
  features        Json?
  created_at      DateTime?       @default(now()) @db.Timestamp(6)
  updated_at      DateTime?       @default(now()) @updatedAt @db.Timestamp(6)
  order_items     OrderItem[]
  stock_online    StockOnline?
  stock_physical  StockPhysical?
  wholesale_price WholesalePrice?

  @@index([brand], map: "idx_products_brand")
  @@index([compatibility], map: "idx_products_compatibility")
  @@index([model], map: "idx_products_model")
  @@map("products")
}

/// Stock disponible para el canal online (1:1 con Product).
model StockOnline {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id String    @unique @db.Uuid
  /// CHECK (quantity >= 0) — presente en el DDL PostgreSQL.
  quantity   Int       @default(0)
  updated_at DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  product    Product   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("stock_online")
}

/// Stock disponible en tienda física (1:1 con Product).
model StockPhysical {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id     String    @unique @db.Uuid
  /// CHECK (quantity >= 0) — presente en el DDL PostgreSQL.
  quantity       Int       @default(0)
  store_location String?   @db.VarChar(255)
  updated_at     DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  product        Product   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("stock_physical")
}

model Order {
  id               String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String          @db.Uuid
  status           String          @default("Pending") @db.VarChar(50)
  /// CHECK (total_amount >= 0) — presente en el DDL PostgreSQL.
  total_amount     Decimal         @db.Decimal(10, 2)
  created_at       DateTime?       @default(now()) @db.Timestamp(6)
  updated_at       DateTime?       @default(now()) @updatedAt @db.Timestamp(6)
  order_items      OrderItem[]
  user             User            @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  payment          Payment?
  shipping_details ShippingDetail?

  @@map("orders")
}

model OrderItem {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id     String    @db.Uuid
  product_id   String    @db.Uuid
  stock_source String    @db.VarChar(20)
  /// CHECK (quantity > 0) — presente en el DDL PostgreSQL.
  quantity     Int
  unit_price   Decimal   @db.Decimal(10, 2)
  created_at   DateTime? @default(now()) @db.Timestamp(6)
  order        Order     @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  product      Product   @relation(fields: [product_id], references: [id], onUpdate: NoAction)

  @@map("order_items")
}

model Payment {
  id                      String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id                String          @unique @db.Uuid
  transfer_reference      String?         @db.VarChar(255)
  /// CHECK (amount >= 0) — presente en el DDL PostgreSQL.
  amount                  Decimal         @db.Decimal(10, 2)
  transaction_date        DateTime        @default(now()) @db.Timestamp(6)
  external_transaction_id String?         @unique @db.VarChar(255)
  created_at              DateTime?       @default(now()) @db.Timestamp(6)
  payment_receipt         PaymentReceipt?
  order                   Order           @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("payments")
}

/// Comprobante de pago subido por el cliente (1:1 con Payment).
model PaymentReceipt {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  payment_id  String    @unique @db.Uuid
  receipt_url String    @db.VarChar(500)
  uploaded_at DateTime? @default(now()) @db.Timestamp(6)
  payment     Payment   @relation(fields: [payment_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("payment_receipts")
}

model ShippingDetail {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id         String    @unique @db.Uuid
  shipping_type    String    @db.VarChar(50)
  /// Latitud con 8 decimales de precisión.
  latitude         Decimal?  @db.Decimal(10, 8)
  /// Longitud con 8 decimales de precisión.
  longitude        Decimal?  @db.Decimal(11, 8)
  quoted_cost      Decimal?  @default(0.00) @db.Decimal(10, 2)
  uber_tracking_id String?   @unique @db.VarChar(255)
  address_line     String?
  created_at       DateTime? @default(now()) @db.Timestamp(6)
  updated_at       DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  order            Order     @relation(fields: [order_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("shipping_details")
}

/// Precio especial para el rol Wholesaler (1 precio mayorista por producto).
model WholesalePrice {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id   String    @unique @db.Uuid
  /// CHECK (price >= 0) — presente en el DDL PostgreSQL.
  price        Decimal   @db.Decimal(10, 2)
  /// Cantidad mínima para acceder al precio mayorista.
  min_quantity Int       @default(1)
  updated_at   DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  product      Product   @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("wholesale_prices")
}

/// Log inmutable de todas las operaciones relevantes del sistema.
/// old_data y new_data usan tipo JSONB nativo de PostgreSQL.
model AuditLog {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?   @db.Uuid
  action     String    @db.VarChar(50)
  table_name String    @db.VarChar(100)
  record_id  String    @db.Uuid
  /// JSONB — soporta indexado GIN y consultas por clave en PostgreSQL.
  old_data   Json?
  /// JSONB — soporta indexado GIN y consultas por clave en PostgreSQL.
  new_data   Json?
  created_at DateTime? @default(now()) @db.Timestamp(6)
  user       User?     @relation(fields: [user_id], references: [id], onUpdate: NoAction)

  @@index([table_name, record_id], map: "idx_audit_logs_table_record")
  @@index([user_id], map: "idx_audit_logs_user_id")
  @@map("audit_logs")
}
